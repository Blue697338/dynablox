@page "/auth/credits"
@model Roblox.Website.Pages.Credits

@{
    Layout = "Shared/_Layout";
}

@section MetaTags {
    <title>Credits</title>
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12 col-lg-6 offset-lg-3">
            <h1>Credits</h1>
            <p><span class="fw-bold">DynaBlox Development Team</span> - Building and maintaining DynaBlox.</p>

            <p><span class="fw-bold">Community Contributors</span> - Thanks to all our community members who report bugs, suggest features, and help make DynaBlox better.</p>

            <p><span class="fw-bold">Original Inspiration</span> - Built on the legacy of classic gaming and community-driven development.</p>

            <p><span class="fw-bold">Special Thanks</span> - To everyone who believes in community-driven development and fair gameplay.</p>

            <p>Join our community on <a href="https://discord.gg/kdgGqqejWY">Discord</a> to be part of DynaBlox!</p>
        </div>
    </div>
</div>